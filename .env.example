# ── NestJS API ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LLM_SERVICE_URL=http://llm:8000
AUDIO_SERVICE_URL=http://audio:8001
# Native dev override (not Docker): AUDIO_SERVICE_URL=http://localhost:8001

# ── Ollama ────────────────────────────────────────────────────
# Dev: Ollama runs natively on your machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Prod (self-hosted, when ready): change to http://ollama:11434
OLLAMA_MODEL=deepseek-r1:14b
# Can be any model Ollama supports: llama3.2, mistral, qwen2.5, etc.

# ── DeepSeek cloud ────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Task routing ──────────────────────────────────────────────
# Maps each task to a provider: "ollama" or "deepseek"
# Available tasks: translation, grammar_check, vocabulary, conversation, pronunciation_feedback

# Dev (all tasks -> local Ollama, no API key needed):
TASK_ROUTING={"translation":"ollama","grammar_check":"ollama","vocabulary":"ollama","conversation":"ollama","pronunciation_feedback":"ollama"}

# Prod early-stage (all tasks -> DeepSeek cloud, pay per token):
# TASK_ROUTING={"translation":"deepseek","grammar_check":"deepseek","vocabulary":"deepseek","conversation":"deepseek","pronunciation_feedback":"deepseek"}

# Prod mixed (when self-hosted Ollama is running):
# TASK_ROUTING={"translation":"deepseek","grammar_check":"ollama","vocabulary":"ollama","conversation":"deepseek","pronunciation_feedback":"ollama"}

# ── Audio service (Faster-Whisper STT + Kokoro TTS) ───────────
# Model sizes: tiny | base | small | medium | large-v3
# Dev: "small" is fast and low-memory
# Prod: "medium" or "large-v3" for better accuracy
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Kokoro TTS default voice and language
# lang_code: a=American English, b=British English, e=Spanish, f=French, j=Japanese, z=Mandarin
KOKORO_DEFAULT_VOICE=af_heart
KOKORO_DEFAULT_LANG=a

# Piper TTS — for languages Kokoro doesn't support
# Each var sets the default voice for that language. Override to switch voices.
PIPER_VOICE_DE=de_DE-thorsten-medium       # German  (alt: de_DE-kerstin-low, de_DE-eva_k-x_low)
PIPER_VOICE_NL=nl_NL-mls-medium            # Dutch
PIPER_VOICE_PL=pl_PL-mls-medium            # Polish  (alt: pl_PL-gosia-medium)
PIPER_VOICE_RU=ru_RU-ruslan-medium         # Russian (alt: ru_RU-denis-medium, ru_RU-irina-medium)
PIPER_VOICE_TR=tr_TR-dfki-medium           # Turkish
PIPER_VOICE_AR=ar_JO-kareem-medium         # Arabic
PIPER_VOICE_CS=cs_CZ-jirka-medium          # Czech
PIPER_VOICE_SV=sv_SE-nst-medium            # Swedish
PIPER_VOICE_NB=nb_NO-talesyntese-medium    # Norwegian
PIPER_VOICE_DA=da_DK-talesyntese-medium    # Danish
PIPER_VOICE_FI=fi_FI-harri-medium          # Finnish
PIPER_VOICE_EL=el_GR-rapunzelina-low       # Greek
PIPER_VOICE_UK=uk_UA-lada-x_low            # Ukrainian
PIPER_VOICE_KO=ko_KR-dawn-x_low            # Korean  (alt: ko_KR-kss-medium)
PIPER_VOICE_VI=vi_VN-25hours_single-low    # Vietnamese
PIPER_VOICE_HU=hu_HU-anna-medium           # Hungarian (alt: hu_HU-berta-medium)
PIPER_VOICE_RO=ro_RO-mihai-medium          # Romanian
PIPER_VOICE_SK=sk_SK-lili-medium           # Slovak
PIPER_VOICE_CA=ca_ES-upc_ona-medium        # Catalan (alt: ca_ES-upc_pau-medium)
PIPER_VOICE_SR=sr_RS-serbski_institut-medium # Serbian
