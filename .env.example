# ── NestJS API ────────────────────────────────────────────────
PORT=3000
NODE_ENV=development
LLM_SERVICE_URL=http://llm:8000
AUDIO_SERVICE_URL=http://audio:8001
# Native dev override (not Docker): AUDIO_SERVICE_URL=http://localhost:8001

# ── Ollama ────────────────────────────────────────────────────
# Dev: Ollama runs natively on your machine
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Prod (self-hosted, when ready): change to http://ollama:11434
OLLAMA_MODEL=deepseek-r1:14b
# Can be any model Ollama supports: llama3.2, mistral, qwen2.5, etc.

# ── DeepSeek cloud ────────────────────────────────────────────
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat

# ── Task routing ──────────────────────────────────────────────
# Maps each task to a provider: "ollama" or "deepseek"
# Available tasks: translation, grammar_check, vocabulary, conversation, pronunciation_feedback

# Dev (all tasks -> local Ollama, no API key needed):
TASK_ROUTING={"translation":"ollama","grammar_check":"ollama","vocabulary":"ollama","conversation":"ollama","pronunciation_feedback":"ollama"}

# Prod early-stage (all tasks -> DeepSeek cloud, pay per token):
# TASK_ROUTING={"translation":"deepseek","grammar_check":"deepseek","vocabulary":"deepseek","conversation":"deepseek","pronunciation_feedback":"deepseek"}

# Prod mixed (when self-hosted Ollama is running):
# TASK_ROUTING={"translation":"deepseek","grammar_check":"ollama","vocabulary":"ollama","conversation":"deepseek","pronunciation_feedback":"ollama"}

# ── Audio service (Faster-Whisper STT + Kokoro TTS) ───────────
# Model sizes: tiny | base | small | medium | large-v3
# Dev: "small" is fast and low-memory
# Prod: "medium" or "large-v3" for better accuracy
WHISPER_MODEL_SIZE=small
WHISPER_DEVICE=cpu
WHISPER_COMPUTE_TYPE=int8

# Kokoro TTS default voice and language
# lang_code: a=American English, b=British English, e=Spanish, f=French, j=Japanese, z=Mandarin
KOKORO_DEFAULT_VOICE=af_heart
KOKORO_DEFAULT_LANG=a
